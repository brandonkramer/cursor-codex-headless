{
  "name": "codex-headless",
  "version": "0.2.1",
  "description": "Codex headless orchestration: MCP tools (review/implement/probe), profiles, and agent skills for review, implementation, computer-use, and built-in codex MCP.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "codex-headless": "./bin/codex-headless",
    "codex-headless-mcp": "./bin/codex-headless-mcp"
  },
  "scripts": {
    "cli": "node --import tsx src/cli.ts",
    "mcp": "node --import tsx src/mcp/server.ts",
    "install:codex": "bash scripts/install.sh",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^6.0.3"
  }
}
